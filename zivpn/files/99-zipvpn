#!/bin/sh
# /etc/hotplug.d/iface/99-zipvpn
# Auto re-apply ZiVPN server route when the selected WAN interface:
#   - comes up (ifup)        → modem restart, cable reconnect
#   - changes IP (ifupdate)  → DHCP renew, ISP IP rotation (e.g. XL every 2h)

# Only act on ifup or ifupdate
case "$ACTION" in
    ifup|ifupdate) ;;
    *) exit 0 ;;
esac

# Only act if ZiVPN is running
pgrep -f '/etc/zipvpn/core/zivpn' >/dev/null 2>&1 || exit 0

RUN="/etc/zipvpn/run"

# Read the configured WAN interface
WAN_IFACE="$(uci -q get zipvpn.main.wan_iface)"
[ -z "$WAN_IFACE" ] && exit 0

# Only act on the interface we care about
[ "$INTERFACE" = "$WAN_IFACE" ] || exit 0

# Read the REAL server IP that was resolved at start time (before Mihomo hijacks DNS).
# DO NOT resolve the hostname again here — Mihomo fake-ip will return 198.18.x.x!
[ -f "$RUN/bypass_ips" ] || exit 0
SERVER_IP="$(head -1 "$RUN/bypass_ips" 2>/dev/null)"
[ -z "$SERVER_IP" ] && exit 0

# Get the new gateway from the interface
WAN_GW="$(ubus call network.interface."$WAN_IFACE" status 2>/dev/null | jsonfilter -e '@.route[@.target="0.0.0.0"].nexthop' 2>/dev/null)"
L3_DEV="$(ubus call network.interface."$WAN_IFACE" status 2>/dev/null | jsonfilter -e '@.l3_device' 2>/dev/null)"

[ -z "$WAN_GW" ] || [ -z "$L3_DEV" ] && exit 0

# Check if route already correct — avoid spamming logs on every ifupdate
CURRENT="$(ip route get "$SERVER_IP" 2>/dev/null | awk '/via/{print $3"|"$5; exit}')"
[ "$CURRENT" = "$WAN_GW|$L3_DEV" ] && exit 0

# Ensure the kernel device is UP (ModemManager quirk)
ip link set "$L3_DEV" up 2>/dev/null

# Replace the route with the new gateway
ip route replace "$SERVER_IP" via "$WAN_GW" dev "$L3_DEV" 2>/dev/null
logger -t ZIPVPN "Hotplug($ACTION): Route updated $SERVER_IP via $WAN_GW dev $L3_DEV"

# Also refresh the bypass ip rule
ip rule del to "$SERVER_IP" lookup main 2>/dev/null
ip rule add to "$SERVER_IP" lookup main prio 10 2>/dev/null
