#!/bin/sh /etc/rc.common

START=95
USE_PROCD=1

start_service() {
	local enabled=$(uci -q get dwtool.watchdog.enabled || echo "0")
	[ "$enabled" -eq 1 ] || return 0

	procd_open_instance
	procd_set_param command /bin/sh /usr/share/dwtool/watchdog.sh
	procd_set_param respawn
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	# Clean up any leftover watchdog policy routing rules
	ip rule del table 40 2>/dev/null
	ip rule del table 40 2>/dev/null
	ip route del default table 40 2>/dev/null
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "dwtool"
}
