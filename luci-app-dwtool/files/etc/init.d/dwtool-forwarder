#!/bin/sh /etc/rc.common
# /etc/init.d/dwtool-forwarder
# Telegram SMS Forwarder service daemon for Dell DW5821e Toolkits

START=99
STOP=10
USE_PROCD=1

start_service() {
    local enabled=$(uci -q get dwtool.telegram.enabled || echo "0")
    [ "$enabled" = "1" ] || return 0

    local bot_token=$(uci -q get dwtool.telegram.bot_token)
    local chat_id=$(uci -q get dwtool.telegram.chat_id)
    [ -n "$bot_token" ] && [ -n "$chat_id" ] || return 0

    procd_open_instance "main"
    procd_set_param command /bin/sh -c "
        logger -t dwtool-forwarder 'Telegram SMS Forwarder service started'
        while true; do
            [ -f /usr/share/dwtool/telegram_forward.sh ] && /usr/share/dwtool/telegram_forward.sh
            sleep 15
        done
    "
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "dwtool"
}
