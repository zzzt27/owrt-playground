config dwtool 'global'
	option port '/dev/ttyUSB0'
	option boot_fix '1'
	option auto_qmi '0'

config custom_cmd
	option label 'Check AT'
	option command 'AT'

config custom_cmd
	option label 'Device Info'
	option command 'ATI'

config custom_cmd
	option label 'Signal Quality'
	option command 'AT+CSQ'

config custom_cmd
	option label 'CA Info'
	option command 'AT^CA_INFO?'

config custom_cmd
	option label 'Band Lock Status'
	option command 'AT^SLBAND?'

config custom_cmd
	option label 'Temperature'
	option command 'AT+TEMP?'

config custom_cmd
	option label 'Voltage'
	option command 'AT+VOLT?'

config custom_cmd
	option label 'Neighbor Cells'
	option command 'AT+VZWRSRP?'

config telegram 'telegram'
	option enabled '0'
	option bot_token ''
	option chat_id ''

config watchdog 'watchdog'
	option enabled '0'
	option check_interval '60'
	option retry_interval '10'
	option check_type 'direct'
	option direct_target 'https://connectivitycheck.gstatic.com/generate_204'
	option direct_method 'curl'
	option direct_interface ''
	option failure_threshold '3'
	option action_type 'airplane'
	option enable_custom_script '0'
	option custom_script ''
	option mihomo_api_url 'http://127.0.0.1:9090'
	option mihomo_api_secret ''
	option mihomo_proxy ''

